# Upstash Redis — REST credentials (copy from the Upstash console → your database → "REST API")
# Use the HTTPS REST URL and the REST token, NOT the redis:// connection string.
UPSTASH_REDIS_REST_URL="https://your-db-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-rest-token"

# Set these as Environment Variables in Vercel (Project → Settings → Environment Variables),
# then Redeploy. For local testing against the real DB, copy this file to ".env"
# and run: vercel dev   (or: node --env-file=.env serve.cjs uses the in-memory mock, not real Redis)
